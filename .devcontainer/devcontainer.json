{
  "name": "DevOps – Configuration Management Lab",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/python:1": {
      "version": "os-provided",
      "installPipx": true
    }
  },
  "postCreateCommand": "pipx install ansible-core && echo '✅ Ansible ready!' && ansible --version",
  "forwardPorts": [
    5000
  ],
  "portsAttributes": {
    "5000": {
      "label": "Flask App",
      "onAutoForward": "notify"
    }
  },
  "remoteUser": "vscode"
}